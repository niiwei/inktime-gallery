{
  "name": "inktime-gallery",
  "private": true,
  "version": "0.1.0",
  "description": "Local-first macOS photo memory gallery and wallpaper automation app.",
  "license": "MIT",
  "author": "InkTime Gallery contributors",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/niiwei/inktime.git"
  },
  "bugs": {
    "url": "https://github.com/niiwei/inktime/issues"
  },
  "homepage": "https://github.com/niiwei/inktime#readme",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "node server/index.js",
    "dev:vite": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "electron:dev": "npm run build && electron .",
    "electron:pack": "npm run build && electron-builder --mac dir",
    "electron:dist": "npm run build && electron-builder --mac dmg",
    "preview": "vite preview --host 127.0.0.1",
    "wallpaper:random": "node scripts/set-random-wallpaper.js"
  },
  "build": {
    "appId": "com.inktime.gallery",
    "productName": "InkTime",
    "asar": true,
    "asarUnpack": [
      "node_modules/sharp/**",
      "node_modules/@img/**",
      "assets/**",
      "scripts/**"
    ],
    "files": [
      "dist/**",
      "assets/**",
      "electron/**",
      "server/**",
      "scripts/**",
      "config/gallery.config.json",
      "data/**",
      "reference/InkTime/data/world_cities_zh.csv",
      "package.json",
      "node_modules/**"
    ],
    "mac": {
      "icon": "assets/app-icon.icns",
      "category": "public.app-category.photography",
      "target": [
        "dir",
        "dmg"
      ]
    },
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "exifr": "^7.1.3",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "openai": "^6.11.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "playwright": "^1.61.0"
  }
}
